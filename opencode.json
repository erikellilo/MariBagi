{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "deepseek/deepseek-v4-pro",
  "small_model": "deepseek/deepseek-v4-flash",
  "default_agent": "general",
  "experimental": {
    "disable_paste_summary": true
  },
  "compaction": {
    "auto": true,
    "tail_turns": 18
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:./.opencode/.env}"
      }
    }
  },
  "plugin": ["./.opencode/node_modules/superpowers"],
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      ".opencode/.env": "allow",
      ".env*": "deny",
      "**/.env*": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny",
      "*.p12": "deny",
      "**/*.p12": "deny",
      "*.jks": "deny",
      "**/*.jks": "deny",
      "*credentials*": "deny",
      "**/*credentials*": "deny",
      "**/Logs/**": "deny"
    },
    "edit": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      ".opencode/.env": "allow",
      ".env*": "deny",
      "**/.env*": "deny",
      "*.pem": "deny",
      "**/*.pem": "deny",
      "*.key": "deny",
      "**/*.key": "deny",
      "*.p12": "deny",
      "**/*.p12": "deny",
      "*.jks": "deny",
      "**/*.jks": "deny",
      "*credentials*": "deny",
      "**/*credentials*": "deny",
      "**/node_modules/**": "deny",
      "**/dist/**": "deny",
      "package-lock.json": "deny"
    },
    "external_directory": {
      "/tmp": "allow",
      "/tmp/**": "allow"
    },
    "skill": {
      "code-reviewer": "allow",
      "test-master": "allow",
      "api-designer": "allow",
      "secure-code-guardian": "allow",
      "planning": "allow"
    },
    "bash": {
      "*": "allow",
      "*.env*": "deny",
      "*.pem*": "deny",
      "*.key*": "deny",
      "*.p12*": "deny",
      "*.jks*": "deny",
      "~/.ssh/*": "deny",
      "~/.gnupg/*": "deny",
      "~/.aws/*": "deny",
      "~/.azure/*": "deny",
      "~/.kube/*": "deny",
      "~/.docker/*": "deny",
      "git push --force*": "ask",
      "git push -f*": "ask",
      "git reset --hard*": "ask",
      "git clean -f*": "ask",
      "git checkout -- *": "ask",
      "git restore *": "ask",
      "del *": "ask",
      "rmdir *": "ask",
      "rm *": "ask",
      "shutdown*": "ask",
      "reboot*": "ask"
    }
  },
  "agent": {
    "general": {
      "description": "Primary orchestrator for MariBagi (React + Vite + Redux) — planning, handoff, and review",
      "model": "zai-coding-plan/glm-5.2",
      "mode": "primary",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "task": "allow"
      },
      "prompt": "{file:./.opencode/prompts/coding-guideline.md}\n\nWhen you need to create or modify files, write code, or execute commands that make changes to the codebase, always delegate the work to the `executor` subagent using the Task tool. You are an orchestrator — you plan, review, and report; the executor implements."
    },
    "build": {
      "description": "Coding agent — implements, tests, and validates changes",
      "model": "deepseek/deepseek-v4-flash",
      "mode": "all",
      "permission": {
        "task": "allow"
      },
      "prompt": "{file:./.opencode/prompts/coding-guideline.md}"
    },
    "plan": {
      "description": "Research and structured implementation planning",
      "model": "zai-coding-plan/glm-5.2",
      "mode": "all",
      "permission": {
        "edit": {
          "*": "deny",
          ".work/*": "allow"
        },
        "task": "allow"
      },
      "prompt": "{file:./.opencode/prompts/coding-guideline.md}"
    },
    "explore": {
      "description": "Codebase exploration — search files, find patterns, understand architecture. Uses context7 for documentation lookup.",
      "model": "deepseek/deepseek-v4-pro",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": "deny",
        "task": "deny"
      },
      "prompt": "{file:./.opencode/prompts/coding-guideline.md}\n\nWhen you need to search docs or look up API references, use the `context7` tools. Before writing any code, check context7 for the latest documentation on frameworks and libraries in use."
    },
    "executor": {
      "description": "Execution subagent — builds, tests, and validates",
      "model": "deepseek/deepseek-v4-flash",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "task": "deny"
      },
      "prompt": "{file:./.opencode/prompts/coding-guideline.md}"
    },
    "reviewer": {
      "description": "Code review agent — reviews diffs for bugs, security, style",
      "model": "deepseek/deepseek-v4-pro",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "edit": {
          "*": "deny",
          ".work/*": "allow"
        },
        "task": "deny"
      },
      "prompt": "{file:./.opencode/prompts/coding-guideline.md}"
    },
    "simplifier": {
      "description": "Reviews changed code for reuse, quality, and efficiency",
      "model": "deepseek/deepseek-v4-pro",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "task": "allow"
      },
      "prompt": "{file:./.opencode/prompts/coding-guideline.md}"
    }
  }
}
